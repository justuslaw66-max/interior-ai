{
  "name": "interior-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_DISABLE_TURBOPACK=1 next dev --webpack",
    "dev:reset": "pkill -f \"next dev --webpack\" || true && rm -f .next-cache/dev/lock && NEXT_DISABLE_TURBOPACK=1 next dev --webpack",
    "build": "next build",
    "build:e2e": "APP_ENV=development next build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:e2e:pro-upgrade": "playwright test tests/e2e/pro-upgrade.spec.ts",
    "test:e2e:pro-upgrade:ui": "playwright test tests/e2e/pro-upgrade.spec.ts --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "branch:new": "bash scripts/new-feature-branch.sh",
    "import:model": "npx ts-node --transpile-only --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' scripts/import-model.ts",
    "import:bulk": "npx ts-node --transpile-only --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' scripts/bulk-import-models.ts",
    "backfill:finishes": "npx ts-node --transpile-only --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' scripts/backfill-finish-mappings.ts",
    "db:backup": "bash scripts/backup-db.sh",
    "db:restore": "bash scripts/restore-db.sh",
    "studio": "node -r dotenv/config ./node_modules/.bin/prisma studio --port 5555",
    "vercel-build": "prisma generate && prisma migrate deploy && next build",
    "seed:finishes": "npx prisma db seed",
    "test:catalog-governance": "npx ts-node --transpile-only --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' scripts/test-catalog-governance-validations.ts",
    "test:catalog-panel": "npx ts-node --transpile-only --compiler-options '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' scripts/test-catalog-panel-logic.ts"
  },
  "prisma": {
    "seed": "npx ts-node --transpile-only --compiler-options={\"module\":\"CommonJS\",\"moduleResolution\":\"node\"} prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.3.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@sentry/nextjs": "^10.42.0",
    "@types/pdfkit": "^0.17.5",
    "jspdf": "^4.2.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^6.22.0",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.18.0",
    "posthog-js": "^1.347.2",
    "posthog-node": "^5.24.15",
    "prisma": "^7.3.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^20.3.1",
    "three": "^0.182.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
