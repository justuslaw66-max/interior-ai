# Staging Environment Configuration Template
# Copy this to .env.staging and fill in actual values
# DO NOT commit .env.staging with real secrets!

# Environment
APP_ENV=staging
NODE_ENV=production

# App Configuration
APP_ORIGIN=https://staging.yourdomain.com
NEXTAUTH_URL=https://staging.yourdomain.com

# Database (Neon - Staging DB)
DATABASE_URL=postgresql://user:password@staging-host.neon.tech/neondb?sslmode=require

# Authentication
AUTH_SECRET=generate-with-openssl-rand-base64-32
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-secret

# OpenAI (use test key if available, or prod with low quotas)
OPENAI_API_KEY=sk-test-your-staging-key

# Shopify (Staging Store)
SHOPIFY_STORE_DOMAIN=your-staging-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-staging-storefront-token
SHOPIFY_API_VERSION=2026-01

# Stripe (MUST use test keys)
STRIPE_SECRET_KEY=sk_test_your-staging-key
STRIPE_WEBHOOK_SECRET=whsec_your-staging-webhook-secret
STRIPE_PRICE_PRO_MONTHLY=price_test_monthly_id
STRIPE_PRICE_PRO_YEARLY=price_test_yearly_id

# Analytics & Monitoring
POSTHOG_KEY=phc_your-staging-project-key
NEXT_PUBLIC_POSTHOG_KEY=phc_your-staging-project-key
SENTRY_DSN=https://your-staging-sentry-dsn@sentry.io/project
NEXT_PUBLIC_SENTRY_DSN=https://your-staging-sentry-dsn@sentry.io/project

# Email (Resend)
RESEND_API_KEY=re_your-staging-key
EMAIL_FROM=Interior AI Staging <staging@yourdomain.com>

# Admin Access (comma-separated emails)
ADMIN_EMAILS=admin@yourdomain.com,dev@yourdomain.com

# Feature Flags (optional - defaults to true)
FEATURE_AI=true
FEATURE_CHECKOUT=true
FEATURE_EMAIL=true

# Optional: Catalog Validation
CATALOG_STRICT_VALIDATION=false
